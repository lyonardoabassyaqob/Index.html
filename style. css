/* الإعدادات العامة والتصفير */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Cairo', sans-serif;
}

body {
    background-color: #0c0d14; /* لون غامق فخم */
    color: #ffffff;
    overflow-x: hidden;
}

/* تنسيق الهيدر السينمائي العالي */
.hero {
    position: relative;
    height: 70vh;
    background: url('https://images.unsplash.com/photo-1509198397868-475647b2a1e5?w=1600') no-repeat center center/cover;
    display: flex;
    align-items: center;
    padding: 0 10%;
}

.hero .overlay {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: linear-gradient(to top, #0c0d14 10%, rgba(12, 13, 20, 0.4) 50%, rgba(0,0,0,0.8));
}

.hero-content {
    position: relative;
    z-index: 2;
    max-width: 600px;
}

.badge {
    background: #e50914; /* أحمر نيتفليكس الفاخر */
    padding: 5px 12px;
    border-radius: 20px;
    font-size: 14px;
    font-weight: bold;
}

.hero h1 {
    font-size: 55px;
    margin: 15px 0;
    font-weight: 900;
    text-shadow: 2px 4px 10px rgba(0,0,0,0.7);
}

.hero .story {
    font-size: 18px;
    color: #b3b3b3;
    line-height: 1.6;
    margin-bottom: 30px;
}

.hero-buttons {
    display: flex;
    gap: 15px;
}

.btn-play, .btn-fav {
    padding: 12px 25px;
    border-radius: 5px;
    font-size: 16px;
    font-weight: bold;
    cursor: pointer;
    text-decoration: none;
    transition: 0.3s ease;
}

.btn-play {
    background-color: #ffffff;
    color: #000;
}

.btn-play:hover {
    background-color: #e50914;
    color: #fff;
}

.btn-fav {
    background-color: rgba(255,255,255,0.1);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.4);
}

.btn-fav:hover {
    background-color: rgba(255,255,255,0.2);
}

/* قسم محتوى الحلقات والبحث */
.container {
    padding: 40px 10%;
}

.section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    flex-wrap: wrap;
    gap: 15px;
}

.text-danger { color: #e50914; }

.search-box {
    position: relative;
}

.search-box i {
    position: absolute;
    right: 15px;
    top: 50%;
    transform: translateY(-50%);
    color: #888;
}

.search-box input {
    background: #1c1d24;
    border: 1px solid #333;
    padding: 10px 45px 10px 20px;
    color: white;
    border-radius: 25px;
    width: 300px;
    outline: none;
    transition: 0.3s;
}

.search-box input:focus {
    border-color: #e50914;
    box-shadow: 0 0 10px rgba(229, 9, 20, 0.5);
}

/* شبكة الحلقات والتأثيرات الخرافية (Hover) */
.episodes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 25px;
}

.card {
    background: #14161f;
    border-radius: 8px;
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.3s;
    border-bottom: 3px solid transparent;
}

.card:hover {
    transform: translateY(-10px) scale(1.03);
    box-shadow: 0 15px 30px rgba(229, 9, 20, 0.2);
    border-color: #e50914;
}

.card-img {
    position: relative;
    height: 160px;
}

.card-img img {
    width: 100%; height: 100%; object-fit: cover;
}

.play-hover {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0.5);
    display: flex; justify-content: center; align-items: center;
    font-size: 40px; color: #fff; opacity: 0;
    transition: 0.3s;
}

.card:hover .play-hover { opacity: 1; color: #e50914; }

.duration {
    position: absolute; bottom: 10px; left: 10px;
    background: rgba(0,0,0,0.8); padding: 2px 8px; font-size: 12px; border-radius: 3px;
}

.card-body {
    padding: 15px;
}

.card-body h3 {
    font-size: 16px; margin-bottom: 8px; font-weight: bold;
}

.card-body p {
    font-size: 13px; color: #999; line-height: 1.5; margin-bottom: 15px;
    height: 40px; overflow: hidden;
}

.btn-watch {
    width: 100%; background: #1c1d24; border: 1px solid #333; color: white;
    padding: 8px; border-radius: 4px; cursor: pointer; font-weight: bold; transition: 0.3s;
}

.card:hover .btn-watch {
    background: #e50914; border-color: #e50914;
}

/* شاشة تشغيل الفيديو المنبثقة الذكية (Modal) */
.video-modal {
    position: fixed;
    top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0.9); z-index: 999;
    display: flex; justify-content: center; align-items: center;
    opacity: 0; pointer-events: none; transition: 0.3s ease;
}

.video-modal.active {
    opacity: 1; pointer-events: auto;
}

.modal-content {
    width: 80%; max-width: 800px; position: relative;
}

.close-btn {
    position: absolute; top: -40px; left: 0;
    font-size: 35px; color: white; cursor: pointer;
}

.iframe-container {
    position: relative; padding-bottom: 56.25%; height: 0;
}

.iframe-container iframe {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    border-radius: 8px; box-shadow: 0 0 30px rgba(229, 9, 20, 0.5);
}

footer {
    text-align: center; padding: 30px; color: #555; background: #08090d; font-size: 14px;
}
